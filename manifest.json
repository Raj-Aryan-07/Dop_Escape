{
  "manifest_version": 3,
  "name": "Dopamine De-escalator",
  "version": "2.0.0",
  "description": "AI-powered browser extension to reduce digital addiction — now with local Ollama AI support",
  "permissions": ["scripting", "activeTab", "storage", "tabs", "alarms"],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://reddit.com/*",
    "https://www.reddit.com/*",
    "https://instagram.com/*",
    "https://www.instagram.com/*",
    "https://youtube.com/*",
    "https://www.youtube.com/*",
    "https://facebook.com/*",
    "https://www.facebook.com/*",
    "https://tiktok.com/*",
    "https://www.tiktok.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": [
      "https://twitter.com/*", "https://x.com/*",
      "https://reddit.com/*",  "https://www.reddit.com/*",
      "https://instagram.com/*", "https://www.instagram.com/*",
      "https://youtube.com/*",  "https://www.youtube.com/*",
      "https://facebook.com/*", "https://www.facebook.com/*",
      "https://tiktok.com/*",   "https://www.tiktok.com/*"
    ],
    "js": ["content.js"],
    "css": ["content-styles.css"]
  }],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dopamine De-escalator"
  }
}
