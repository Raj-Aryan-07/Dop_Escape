{
  "manifest_version": 3,
  "name": "Dopamine De-escalator",
  "version": "2.1.0",
  "description": "AI-powered browser extension to reduce digital addiction — local Ollama AI support",
  "permissions": [
    "scripting",
    "activeTab",
    "storage",
    "tabs",
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://reddit.com/*",
    "https://www.reddit.com/*",
    "https://instagram.com/*",
    "https://www.instagram.com/*",
    "https://youtube.com/*",
    "https://www.youtube.com/*",
    "https://facebook.com/*",
    "https://www.facebook.com/*",
    "https://tiktok.com/*",
    "https://www.tiktok.com/*",
    "http://localhost/*",
    "http://localhost:*/*",
    "http://127.0.0.1/*",
    "http://127.0.0.1:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://reddit.com/*",
        "https://www.reddit.com/*",
        "https://instagram.com/*",
        "https://www.instagram.com/*",
        "https://youtube.com/*",
        "https://www.youtube.com/*",
        "https://facebook.com/*",
        "https://www.facebook.com/*",
        "https://tiktok.com/*",
        "https://www.tiktok.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content-styles.css"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Dopamine De-escalator"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "settings.html",
        "dashboard.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}