{
  "manifest_version": 3,
  "name": "Dopamine De-escalator",
  "version": "1.0.0",
  "description": "AI-powered browser extension to reduce digital addiction",
  "permissions": ["scripting", "activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://twitter.com/*",
    "https://x.com/*",
    "https://reddit.com/*",
    "https://www.reddit.com/*",
    "https://instagram.com/*",
    "https://www.instagram.com/*",
    "https://youtube.com/*",
    "https://www.youtube.com/*",
    "https://facebook.com/*",
    "https://www.facebook.com/*",
    "https://tiktok.com/*",
    "https://www.tiktok.com/*"
  ],
  "background": {"service_worker": "background.js"},
  "content_scripts": [{
    "matches": ["https://twitter.com/*", "https://x.com/*", "https://reddit.com/*", "https://www.reddit.com/*", "https://instagram.com/*", "https://www.instagram.com/*", "https://youtube.com/*", "https://www.youtube.com/*", "https://facebook.com/*", "https://www.facebook.com/*", "https://tiktok.com/*", "https://www.tiktok.com/*"],
    "js": ["content.js"],
    "css": ["content-styles.css"]
  }],
  "action": {"default_popup": "popup.html", "default_title": "Dopamine De-escalator"}
}